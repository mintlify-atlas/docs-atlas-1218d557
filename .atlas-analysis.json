  "keyFeatures": [
    "Download updated DATs from multiple sources (dat-omatic, redump, pleasuredome)",
    "Process DATs to generate emulator-compatible folder structures",
    "Deduplicate ROMs across DAT files",
    "Plugin system with official seeds for various ROM collections",
    "Import DATs from existing RomVault installations",
    "Mark MIA (Missing In Action) ROMs",
    "Configuration management with local and global settings",
    "Doctor command to validate seed installations"
  ],
  "publicApiSurface": [
    "datoso seed list",
    "datoso seed details <seed>",
    "datoso <seed> --fetch",
    "datoso <seed> --process",
    "datoso all --fetch",
    "datoso all --process",
    "datoso dat -d <dat_name>",
    "datoso dat -d <seed>:<dat_name> --set <property>=<value>",
    "datoso dat -d <seed>:<dat_name> --unset <property>",
    "datoso config",
    "datoso config --set <section>.<option> <value>",
    "datoso config --get <section>.<option>",
    "datoso config --rules-update",
    "datoso config --mia-update",
    "datoso doctor [seed]",
    "datoso import",
    "datoso deduper -input <input_dat> -p <parent_dat>",
    "datoso log"
  ]
